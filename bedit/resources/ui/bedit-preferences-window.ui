<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template class="BeditPreferencesWindow" parent="BrkPreferencesWindow">
    <property name="title">Bedit Preferences</property>
    <property name="default-width">640</property>
    <property name="default-height">480</property>
    <child>
      <object class="BrkPreferencesPage">
        <property name="name">editor</property>
        <property name="title">Editor</property>
        <child>
          <object class="BrkPreferencesGroup">
            <property name="title">Display</property>
            <child>
              <object class="BrkSwitchRow" id="show_line_numbers_row">
                <property name="title">Show Line Numbers</property>
                <property name="subtitle">Show line numbers at the side of the screen</property>
              </object>
            </child>
            <child>
              <object class="BrkSwitchRow" id="show_right_margin_row">
                <property name="title">Show Right Margin</property>
                <property name="subtitle">Draw a vertical line at a fixed column offset</property>
              </object>
            </child>
            <child>
              <object class="BrkSpinRow" id="right_margin_position_row">
                <property name="title">Right Margin Position</property>
                <property name="subtitle">Offset at which to draw the right margin, if enabled</property>
              </object>
            </child>
            <child>
              <object class="BrkSwitchRow" id="show_overview_map_row">
                <property name="title">Show Overview Map</property>
                <property name="subtitle">Show a miniature view of the document beside the editor</property>
              </object>
            </child>
            <child>
              <object class="BrkSwitchRow" id="show_toolbar_row">
                <property name="title">Show Toolbar</property>
                <property name="subtitle">Display the toolbar (containing shortcut buttons) at the top of the screen</property>
              </object>
            </child>
            <child>
              <object class="BrkSwitchRow" id="show_menubar_row">
                <property name="title">Show Menubar</property>
                <property name="subtitle">Display the menubar at the very top of the screen</property>
              </object>
            </child>
            <child>
              <object class="BrkSwitchRow" id="show_statusbar_row">
                <property name="title">Show Statusbar</property>
                <property name="subtitle">Display the statusbar at the bottom of the screen</property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="BrkPreferencesGroup">
            <property name="title">Highlighting</property>
            <child>
              <object class="BrkSwitchRow" id="highlight_selection_row">
                <property name="title">Highlight Matching Selection</property>
                <property name="subtitle">Highlight areas that match the current selection</property>
              </object>
            </child>
            <child>
              <object class="BrkSwitchRow" id="highlight_current_line_row">
                <property name="title">Highlight Current Line</property>
                <property name="subtitle">Highlight the whole of the line containing the cursor</property>
              </object>
            </child>
            <child>
              <object class="BrkSwitchRow" id="highlight_syntax_row">
                <property name="title">Highlight Syntax</property>
                <property name="subtitle">Apply syntax highlighting</property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="BrkPreferencesGroup">
            <property name="title">Indentation</property>
            <child>
              <object class="BrkSwitchRow" id="insert_spaces_instead_of_tabs_row">
                <property name="title">Insert Spaces Instead of Tabs</property>
                <property name="subtitle">Insert spaces instead of tabs when the tab key is pressed</property>
              </object>
            </child>
            <child>
              <object class="BrkSpinRow" id="tab_width_row">
                <property name="title">Tab Width</property>
                <property name="subtitle">The width of a tabulation in characters</property>
              </object>
            </child>
            <child>
              <object class="BrkSwitchRow" id="auto_indent_row">
                <property name="title">Auto-Indent</property>
                <property name="subtitle">Match indentation of the previous line</property>
              </object>
            </child>
            <child>
              <object class="BrkSwitchRow" id="trim_trailing_whitespace_row">
                <property name="title">Trim Trailing Whitespace</property>
                <property name="subtitle">Strip whitespace from the end of lines before saving</property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="BrkPreferencesGroup">
            <property name="title">Word Wrap</property>
            <child>
              <object class="BrkSwitchRow" id="word_wrap_row">
                <property name="title">Word Wrap</property>
                <property name="subtitle">Soft-wrap lines that extend beyond the visible area</property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="BrkPreferencesGroup">
            <property name="title">Spell Checking</property>
            <child>
              <object class="BrkSwitchRow" id="auto_check_spelling_row">
                <property name="title">Check Spelling Automatically</property>
                <property name="subtitle">Check files for spelling errors in real time</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="BrkPreferencesPage">
        <property name="name">appearance</property>
        <property name="title">Appearance</property>
        <child>
          <object class="BrkPreferencesGroup">
            <property name="title">Font</property>
            <child>
              <object class="BrkSwitchRow" id="use_default_font_row">
                <property name="title">Use Default Font</property>
                <property name="subtitle">Use the system monospace font instead of a custom one</property>
              </object>
            </child>
            <!-- <key name="editor-font" type="s"> -->
          </object>
        </child>
        <child>
          <object class="BrkPreferencesGroup">
            <property name="title">Syntax Highlighting</property>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
